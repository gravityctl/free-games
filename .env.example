# Discord webhook URL (required)
DISCORD_WEBHOOK_URL=

# Epic store settings
EPIC_COUNTRY=US
EPIC_LOCALE=en-US
EPIC_INCLUDE_UPCOMING=false

# Enable Steam scraper
ENABLE_STEAM=false

# Enable Twitch drops (Minecraft cape drops only)
ENABLE_TWITCH_DROPS=false

# Twitch drops - comma-separated platforms to include (steam,gog,epic,amazon)
# Defaults to all platforms when ENABLE_TWITCH_DROPS=true and this is empty
TWITCH_DROPS_PLATFORMS=

# Optional: isthereanydeal.com API key for cross-platform game lookups
TWITCH_ITAD_KEY=

# Per-provider schedules (cron format: second minute hour day month weekday)
# Epic: every Thursday at midnight
EPIC_SCHEDULE=0 0 0 * * 4

# Steam: daily at 9am
STEAM_SCHEDULE=0 0 9 * * *

# Twitch drops: daily at noon
TWITCH_DROPS_SCHEDULE=0 0 12 * * *

# Path to notification deduplication store (avoids duplicate notifications)
NOTIFICATION_STORE_PATH=.free-games-store.json

# Custom Discord emojis per provider (Discord native format: <:name:id>)
# Leave empty to use built-in emoji (🔶 epic, 🎲 steam, 🟣 twitch)
EPIC_EMOJI=
STEAM_EMOJI=
TWITCH_EMOJI=

# Base URL for desktop-app redirect service (e.g. https://redirect.example.com)
# When set, adds "Open in App" field linking to this redirect server which
# forwards to the desktop app (steam://, com.epicgames.launcher://, etc.)
REDIRECT_BASE_URL=