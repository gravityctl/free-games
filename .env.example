# Discord webhook URL (required)
DISCORD_WEBHOOK_URL=

# Epic store settings
EPIC_COUNTRY=US
EPIC_LOCALE=en-US
EPIC_INCLUDE_UPCOMING=false

# Enable Steam scraper
ENABLE_STEAM=false

# Twitch drops - comma-separated list of owner names to include
# Leave empty to disable Twitch entirely
# Example: TWITCH_OWNERS=Wargaming,Riot Games,Blizzard
TWITCH_OWNERS=

# Cron schedule (default: every Thursday at midnight)
CHECK_SCHEDULE=0 0 0 * * 4