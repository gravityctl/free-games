# Discord webhook URL (required)
DISCORD_WEBHOOK_URL=

# Epic store settings
EPIC_COUNTRY=US
EPIC_LOCALE=en-US
EPIC_INCLUDE_UPCOMING=false

# Enable Steam scraper
ENABLE_STEAM=false

# Twitch drops - comma-separated platforms to include (steam,gog,epic,amazon)
# See README.md for full list of supported platforms
# Example: TWITCH_PLATFORMS=steam,gog,epic
TWITCH_PLATFORMS=

# Optional: isthereanydeal.com API key for cross-platform game lookups
# Without this, all drops are included (platform filter unavailable)
TWITCH_ITAD_KEY=

# Cron schedule (default: every Thursday at midnight)
CHECK_SCHEDULE=0 0 0 * * 4